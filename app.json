{
  "expo": {
    "name": "LifeMoments",
    "slug": "lifemoments",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "lifemoments",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifemoments.app"
    },
    "android": {
      "package": "com.lifemoments.app",
      "adaptiveIcon": {
        "backgroundColor": "#6C63FF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
